{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow"
    },
    "edit": "allow",
    "list": "allow",
    "glob": "allow",
    "grep": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "bash": {
      "*": "ask",
      "pnpm *": "allow",
      "npx *": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git branch*": "allow",
      "git checkout*": "allow",
      "git stash*": "allow",
      "git fetch*": "allow",
      "git pull*": "allow",
      "git push*": "allow",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git reset --hard*": "deny",
      "ls *": "allow",
      "pwd*": "allow",
      "mkdir *": "allow",
      "cp *": "allow",
      "mv *": "allow",
      "rm -rf *": "deny",
      "sudo *": "deny",
      "docker build *": "allow",
      "docker compose *": "allow",
      "docker inspect *": "allow",
      "docker ps*": "allow",
      "docker logs *": "allow",
      "k6 *": "allow",
      "curl *": "allow",
      "npx playwright *": "allow",
      "python3 *": "allow",
      "node *": "allow",
      "gh *": "allow"
    },
    "task": "allow",
    "lsp": "allow",
    "webfetch": "allow",
    "external_directory": "deny",
    "doom_loop": "ask"
  }
}
