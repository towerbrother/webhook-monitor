{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": "allow",
    "bash": {
      "*": "allow",
      "pnpm *": "allow",
      "npm *": "allow",
      "git status*": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "git checkout *": "allow",
      "git rev-parse *": "allow",
      "grep *": "allow",
      "cat *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "curl *": "allow",
      "gh *": "allow",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf $HOME": "deny",
      "rm -rf .": "deny",
      "rm -rf ..": "deny",
      "sudo *": "deny",
      "chmod 777 *": "deny",
      "> /dev/*": "deny",
      "dd *": "deny",
      "mkfs*": "deny",
      ":(){ :|:& };:": "deny",
      "git push *": "deny",
      "git push": "deny",
      "git reset --hard *": "deny",
      "git clean -fd*": "deny",
      "git checkout -- .": "deny",
      "git rebase *": "deny",
      "git merge *": "deny",
      "git stash drop *": "deny",
      "git branch -D *": "deny",
      "shutdown *": "deny",
      "reboot *": "deny",
      "kill -9 *": "deny",
      "pkill *": "deny",
      "killall *": "deny",
      "format *": "deny",
      "del /f /s /q *": "deny",
      "del /f *": "deny",
      "rd /s /q *": "deny",
      "rmdir /s /q *": "deny",
      "cmd /c *": "deny",
      "cmd.exe *": "deny",
      "powershell *": "deny",
      "pwsh *": "deny",
      "Start-Process *": "deny",
      "Invoke-Expression *": "deny",
      "iex *": "deny",
      "Set-ExecutionPolicy *": "deny",
      "reg add *": "deny",
      "reg delete *": "deny",
      "regedit *": "deny",
      "net user *": "deny",
      "net localgroup *": "deny",
      "netsh *": "deny",
      "taskkill *": "deny",
      "taskkill /f *": "deny",
      "wmic *": "deny",
      "bcdedit *": "deny",
      "diskpart *": "deny",
      "cipher /w:*": "deny",
      "takeown *": "deny",
      "icacls *": "deny",
      "attrib *": "deny",
      "sfc *": "deny",
      "dism *": "deny"
    },
    "task": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "webfetch": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "external_directory": "deny",
    "doom_loop": "ask"
  }
}
