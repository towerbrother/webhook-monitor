{
  "name": "@repo/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./src/__tests__/helpers.ts",
      "default": "./src/__tests__/helpers.ts"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc",
    "generate": "prisma generate",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:setup": "node scripts/setup-test-db.js",
    "pretest": "node scripts/setup-test-db.js",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.4.1",
    "@prisma/client": "7.4.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "prisma": "7.4.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  }
}
